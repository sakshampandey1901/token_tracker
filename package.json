{
  "name": "token-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Free, local-only LLM token usage tracker for VS Code and Cursor.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @token-tracker/extension watch",
    "build": "pnpm -r build",
    "build:ext": "pnpm --filter @token-tracker/extension build",
    "package:ext": "pnpm --filter @token-tracker/extension package",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  }
}
