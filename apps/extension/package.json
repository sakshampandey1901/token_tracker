{
  "name": "token-tracker",
  "displayName": "Token Tracker",
  "description": "Free, local-only LLM token usage tracker. Works in VS Code and Cursor.",
  "version": "0.1.0",
  "publisher": "token-tracker",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokenTracker",
          "title": "Token Tracker",
          "icon": "media/token-tracker.svg"
        }
      ]
    },
    "views": {
      "tokenTracker": [
        {
          "type": "webview",
          "id": "tokenTracker.sidebar",
          "name": "Dashboard",
          "contextualTitle": "Token Tracker"
        }
      ]
    },
    "commands": [
      {
        "command": "tokenTracker.openDashboard",
        "title": "Token Tracker: Open dashboard in editor"
      },
      {
        "command": "tokenTracker.focusSidebar",
        "title": "Token Tracker: Focus sidebar"
      },
      {
        "command": "tokenTracker.refresh",
        "title": "Token Tracker: Refresh"
      },
      {
        "command": "tokenTracker.reportUsage",
        "title": "Token Tracker: Report usage event (programmatic)"
      },
      {
        "command": "tokenTracker.exportEvents",
        "title": "Token Tracker: Export events to JSON"
      },
      {
        "command": "tokenTracker.clearEvents",
        "title": "Token Tracker: Clear event history"
      }
    ],
    "configuration": {
      "title": "Token Tracker",
      "properties": {
        "tokenTracker.dailyTokenLimit": {
          "type": "number",
          "default": 1000000,
          "minimum": 0,
          "description": "Daily token budget used by the status bar meter. Set to 0 to hide the meter."
        },
        "tokenTracker.dailyTokenLimitClaude": {
          "type": "number",
          "default": 1000000,
          "minimum": 0,
          "description": "Daily token budget for Claude source bars in the dashboard."
        },
        "tokenTracker.dailyTokenLimitCodex": {
          "type": "number",
          "default": 1000000,
          "minimum": 0,
          "description": "Daily token budget for Codex source bars in the dashboard."
        },
        "tokenTracker.localIngestPort": {
          "type": "number",
          "default": 58417,
          "description": "Local HTTP port where other tools can POST usage events (127.0.0.1 only)."
        },
        "tokenTracker.enableLocalIngest": {
          "type": "boolean",
          "default": true,
          "description": "Enable the local loopback HTTP endpoint for usage ingest."
        },
        "tokenTracker.claudeCode.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Watch ~/.claude/projects/**/*.jsonl and auto-record Claude Code CLI usage."
        },
        "tokenTracker.codex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Watch ~/.codex/sessions/**/*.jsonl and auto-record OpenAI Codex CLI usage + rate limits."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "pnpm run build && vsce package --no-dependencies -o token-tracker.vsix",
    "lint": "echo \"(no lint configured)\""
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.1.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.4"
  }
}
